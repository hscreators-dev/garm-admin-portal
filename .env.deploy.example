# ─── Garm production env — copy to `.env`, fill in, then `docker compose up -d --build` ───

# Public URLs where each app will be reachable (used for CORS + email links).
CUSTOMER_APP_URL=https://app.yourdomain.com
ADMIN_APP_URL=https://admin.yourdomain.com

# ── Secrets (REQUIRED — servers refuse to boot in production without these) ──
# JWT_SECRET: 32+ random chars →  openssl rand -base64 48
JWT_SECRET=
# GARM_SECRET_KEY: exactly 64 hex chars (encrypts PII at rest) →  openssl rand -hex 32
GARM_SECRET_KEY=

# ── OTP delivery (see OTP_SETUP.md). Until set, login CANNOT work in production. ──
# SMS: console | http | msg91 | fast2sms | twilio
SMS_PROVIDER=console
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER=GARM
# Email over SMTP (Garm App backend) — any host
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@yourdomain.com
# Email over HTTP API (Admin backend) — resend | brevo | generic
EMAIL_PROVIDER=
EMAIL_API_URL=
EMAIL_API_KEY=

# ── Payments (see SECURITY_REVIEW M1). Until a gateway is wired, online pay is
#    blocked in production (customers pay via coordinator). To enable: ──
PAYMENTS_REQUIRE_GATEWAY=false
PAYMENT_PROVIDER=            # e.g. razorpay
RAZORPAY_KEY_SECRET=
